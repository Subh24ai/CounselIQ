# ===========================================================================
# CounselIQ — root environment file (example)
#
# Copy to `.env` at the repo root: `cp .env.example .env`
# This single file is shared by all docker-compose services via `env_file: .env`.
# NEVER commit the real `.env`.
# ===========================================================================

# --- Core -------------------------------------------------------------------
ENVIRONMENT=development            # development | staging | production
LOG_LEVEL=INFO                     # DEBUG | INFO | WARNING | ERROR

# --- Postgres (consumed by the postgres container) --------------------------
POSTGRES_USER=counseliq
POSTGRES_PASSWORD=counseliq
POSTGRES_DB=counseliq

# --- Database URL (consumed by backend/worker — async asyncpg driver) --------
DATABASE_URL=postgresql+asyncpg://counseliq:counseliq@postgres:5432/counseliq

# --- Redis / Celery ---------------------------------------------------------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- AWS (ap-south-1 / Mumbai) ----------------------------------------------
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=ap-south-1
S3_BUCKET_NAME=counseliq-documents
# Local dev only: point boto3 at LocalStack. Leave empty for real AWS.
# AWS_ENDPOINT_URL=http://localhost:4566
# S3_BUCKET_NAME=counseliq-dev

# --- Anthropic Claude -------------------------------------------------------
# Model used by the agents: claude-sonnet-4-6
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- Auth / JWT -------------------------------------------------------------
# Generate a strong secret, e.g.:  openssl rand -hex 32
JWT_SECRET_KEY=change-me-generate-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# --- CORS (comma-separated list of allowed browser origins) -----------------
CORS_ORIGINS=http://localhost:3000

# --- Frontend (exposed to the browser; must be NEXT_PUBLIC_*) ----------------
NEXT_PUBLIC_API_URL=http://localhost:8000
