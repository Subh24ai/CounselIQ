# ---------------------------------------------------------------------------
# CounselIQ backend environment (example)
# Copy to .env and fill in real values. Do NOT commit the real .env.
# ---------------------------------------------------------------------------

# Core
ENVIRONMENT=development
LOG_LEVEL=INFO

# Database (async SQLAlchemy URL — uses asyncpg)
DATABASE_URL=postgresql+asyncpg://counseliq:counseliq@postgres:5432/counseliq

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# AWS (ap-south-1 / Mumbai)
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=ap-south-1
S3_BUCKET_NAME=counseliq-documents
# Local dev only: point boto3 at LocalStack. Leave empty for real AWS.
# AWS_ENDPOINT_URL=http://localhost:4566
# S3_BUCKET_NAME=counseliq-dev

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Auth / JWT
JWT_SECRET_KEY=change-me-generate-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# CORS (comma-separated list of allowed origins)
CORS_ORIGINS=http://localhost:3000
